# Phase 3-full test environment — copy to .env.test (gitignored) and fill.
#
# These credentials are used ONLY by tests/integration/discord-guild.test.js
# and any future spec that needs a real Discord round-trip. They never load
# into the production bot's runtime; production keeps using .env.

# Test bot token (a separate Discord application, not the production bot)
# Created at https://discord.com/developers/applications
DISCORD_TEST_BOT_TOKEN=

# The test guild the bot is added to (separate from the production guild)
DISCORD_TEST_GUILD_ID=

# Channel IDs in the test guild (auto-resolved by name at CLI startup —
# this list is informational, not load-bearing)
TEST_CHANNEL_ORDER_FEED=
TEST_CHANNEL_DEALS=
TEST_CHANNEL_OPS=
TEST_CHANNEL_ANNOUNCEMENTS=
TEST_CHANNEL_CARD_SHOP=
TEST_CHANNEL_QUEUE=
TEST_CHANNEL_PACK_BATTLES=
TEST_CHANNEL_GIVEAWAYS=
TEST_CHANNEL_COMMUNITY_GOALS=
TEST_CHANNEL_ANALYTICS=
TEST_CHANNEL_MOMENTS=
TEST_CHANNEL_SHIPPING_LABELS=
TEST_CHANNEL_MINECRAFT=
